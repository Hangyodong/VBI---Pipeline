    "T_bold = T_stored // step_per_tr\n",
    "\n",
    "bytes_per_sim = T_bold * N_REG * 4  # streaming = ~100x less than full\n",
    "\n",
    "print(f\"  Stored dt  : {stored_dt:.1f} ms  \"\n",
